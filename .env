# Server Configuration
PORT=7777
NODE_ENV=development

# MySQL Database (using SQLite for demo - no setup required)
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=root
MYSQL_DB=potato_system

# MQTT Broker
MQTT_BROKER=mqtt://localhost:9000
MQTT_USER=
MQTT_PASSWORD=

# Camera Stream
CAMERA_STREAM_URL=http://192.168.1.100:81/stream
CAMERA_SNAPSHOT_URL=http://192.168.1.100/capture

# ESP32 Device
ESP32_IP=192.168.1.100
ESP32_API_KEY=potato_secret_key_123

# Alert Thresholds
SOIL_MOISTURE_MIN=30
SOIL_MOISTURE_MAX=80
TEMPERATURE_MIN=15
TEMPERATURE_MAX=35
HUMIDITY_MIN=40
HUMIDITY_MAX=85

# Irrigation Settings
MAX_IRRIGATION_DURATION=300000
MIN_IRRIGATION_INTERVAL=3600000
