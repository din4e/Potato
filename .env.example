# Server Configuration
PORT=3000
NODE_ENV=development

# MySQL Database
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your_password_here
MYSQL_DB=potato_system

# MQTT Broker
MQTT_BROKER=mqtt://localhost:1883
MQTT_USER=
MQTT_PASSWORD=

# Camera Stream
CAMERA_STREAM_URL=http://esp32-cam-local-ip:81/stream
CAMERA_SNAPSHOT_URL=http://esp32-cam-local-ip/capture

# ESP32 Device
ESP32_IP=192.168.1.100
ESP32_API_KEY=your_secret_api_key

# Alert Thresholds
SOIL_MOISTURE_MIN=30
SOIL_MOISTURE_MAX=80
TEMPERATURE_MIN=15
TEMPERATURE_MAX=35
HUMIDITY_MIN=40
HUMIDITY_MAX=85

# Irrigation Settings
MAX_IRRIGATION_DURATION=300000
MIN_IRRIGATION_INTERVAL=3600000

# Frontend
FRONTEND_URL=http://localhost:3000

# ============================================
# 监控与通知配置 / Monitoring & Notifications
# ============================================

# 启用通知功能 / Enable notifications
NOTIFICATIONS_ENABLED=true

# === 邮件配置 / Email Configuration ===
EMAIL_ENABLED=false
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password_here

# === 飞书机器人配置 / Feishu Bot Configuration ===
# 获取方式: 飞书群 -> 群设置 -> 机器人 -> 添加机器人 -> 自定义机器人
FEISHU_WEBHOOK=https://open.feishu.cn/open-apis/bot/v2/hook/your_webhook_url

# === 接收人配置 / Recipients ===
# 告警接收人 (逗号分隔的邮件地址)
ALERT_RECIPIENTS=admin@example.com,user@example.com
# 报告接收人 (逗号分隔的邮件地址)
REPORT_RECIPIENTS=user@example.com

# === 掉线检测配置 / Offline Detection ===
# 设备掉线多久后触发告警 (毫秒) / How long before offline alert (ms)
OFFLINE_THRESHOLD=300000
# 5分钟 = 300000
# 10分钟 = 600000
# 30分钟 = 1800000

# === 报告时间配置 / Report Schedule ===
# 每日报告发送时间 (24小时制) / Daily report time (24h format)
DAILY_REPORT_HOUR=8
DAILY_REPORT_MINUTE=0

# 每周报告发送时间 / Weekly report time
WEEKLY_REPORT_DAY=0
WEEKLY_REPORT_HOUR=9
WEEKLY_REPORT_MINUTE=0
# 0=Sunday, 1=Monday, ..., 6=Saturday
