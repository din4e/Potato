# Server Configuration
PORT=3000
NODE_ENV=development

# MySQL Database
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your_password_here
MYSQL_DB=potato_system

# MQTT Broker
MQTT_BROKER=mqtt://localhost:1883
MQTT_USER=
MQTT_PASSWORD=

# Camera Stream
CAMERA_STREAM_URL=http://esp32-cam-local-ip:81/stream
CAMERA_SNAPSHOT_URL=http://esp32-cam-local-ip/capture

# ESP32 Device
ESP32_IP=192.168.1.100
ESP32_API_KEY=your_secret_api_key

# Alert Thresholds
SOIL_MOISTURE_MIN=30
SOIL_MOISTURE_MAX=80
TEMPERATURE_MIN=15
TEMPERATURE_MAX=35
HUMIDITY_MIN=40
HUMIDITY_MAX=85

# Irrigation Settings
MAX_IRRIGATION_DURATION=300000
MIN_IRRIGATION_INTERVAL=3600000

# Frontend
FRONTEND_URL=http://localhost:3000
